{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: backend",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/backend/Moneta.Api.csproj"],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "watch: backend",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project", "${workspaceFolder}/backend/Moneta.Api.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    },
    {
      "label": "dev: frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^(.*)$", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    }
  ]
}
